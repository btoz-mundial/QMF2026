{
  "version": "v2",

  "registry_type": "analytics_metric_registry_v2",

  "description": "Semantic governance registry for analytics metrics. Defines identity, governance and capabilities for official analytics outputs.",

  "metric_types": [
    "deterministic_metric",
    "interpretive_metric",
    "runtime_derivation",
    "system_metric"
  ],

  "lifecycle_statuses": [
    "draft",
    "experimental",
    "active",
    "deprecated",
    "disabled"
  ],

  "interpretation_risk_levels": [
    "low",
    "medium",
    "high"
  ],

  "metrics": [

    {
      "metric_id": "precision_general",

      "version": "v2",

      "metric_type": "deterministic_metric",

      "category": "precision",

      "lifecycle_status": "active",

      "source_layer": "analytics",

      "source_of_truth": [
        "score_details.json"
      ],

      "depends_on": [
        "group.breakdown.correct",
        "knockout.breakdown.*",
        "standings.details"
      ],

      "unit": "percentage",

      "value_range": {
        "min": 0,
        "max": 100
      },

      "supports_history": true,

      "supports_percentiles": true,

      "supports_rankings": true,

      "supports_ranking_tiers": true,

      "supports_timeline": true,

      "minimum_sample_size": 10,

      "activation_rule": "precision_general_activation",

      "interpretation_risk": "low",

      "contract_ref":
        "analytics_contracts_v2.precision_general"
    },



