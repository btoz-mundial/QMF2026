{
  "version": "v1",

  "registry_type": "runtime_insight_registry",

  "description": "Registry for runtime-derived narrative insights generated from official analytics and historical snapshots. Runtime insights are interpretive render artifacts and never official scoring metrics.",

  "insight_categories": [
    "momentum",
    "consistency",
    "dominance",
    "survival",
    "precision",
    "efficiency",
    "community"
  ],

  "severity_levels": [
    "low",
    "medium",
    "high"
  ],

  "persistence_types": [
    "temporary",
    "snapshot_based",
    "tournament_wide"
  ],

  "insights": [

    {
      "insight_id": "mayor_remontada",

      "category": "momentum",

      "source_analytics": [
        "timeline_race"
      ],

      "description": "Detecta al usuario con la mayor subida positiva de ranking entre snapshots.",

      "trigger_type": "ranking_delta",

      "minimum_conditions": {
        "minimum_rank_gain": 5,
        "minimum_snapshots": 2
      },

      "supports_tiers": false,

      "severity": "high",

      "persistence": "snapshot_based"
    },



